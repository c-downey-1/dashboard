# Poultry Intelligence Dashboard — Required API Keys
#
# Copy this file to .env and fill in your keys.
# Then: export $(grep -v '^#' .env | xargs)

# USDA MARS (Livestock Mandatory Reporting)
# Register: https://marketnews.usda.gov/mnp/api
MARS_API_KEY=your_mars_api_key_here

# USDA NASS QuickStats
# Register: https://quickstats.nass.usda.gov/api
NASS_API_KEY=your_nass_api_key_here

# Federal Reserve FRED
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Bureau of Labor Statistics
# Register: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here
